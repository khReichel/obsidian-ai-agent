# Provider: gemini | anthropic | openrouter | groq
LLM_PROVIDER=groq

# API Keys – nur den passenden Key befüllen
GEMINI_API_KEY=dein_key_hier
ANTHROPIC_API_KEY=dein_key_hier
OPENROUTER_API_KEY=dein_key_hier
GROQ_API_KEY=dein_key_hier

# Modell-Name passend zum Provider:
#   groq:        llama-3.1-8b-instant  (schnell, kostenlos)
#   groq:        llama-3.3-70b-versatile  (stärker, kostenlos)
#   gemini:      gemini-2.0-flash
#   anthropic:   claude-haiku-4-5
#   openrouter:  meta-llama/llama-3.1-8b-instruct
DEFAULT_MODEL=llama-3.1-8b-instant

# Für Docker: Pfad auf dem Host-System (Windows: C:\Users\...\Vault)
HOST_VAULT_PATH=/pfad/zu/deinem/obsidian/vault

# Watcher: Intervall in Minuten (Standard: 30)
WATCH_INTERVAL_MINUTES=30

# Für lokale Ausführung ohne Docker:
VAULT_PATH=/pfad/zu/deinem/obsidian/vault
DB_PATH=obsidian_agent.db
